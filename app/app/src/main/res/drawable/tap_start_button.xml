<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true">
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:endColor="@color/accent_green_dark"
                android:startColor="@color/accent_green" />
            <stroke
                android:width="3dp"
                android:color="#3300C853" />
        </shape>
    </item>

    <item>
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:endColor="@color/accent_green"
                android:startColor="#6BFFB2" />
            <stroke
                android:width="3dp"
                android:color="#2200E676" />
        </shape>
    </item>

</selector>
