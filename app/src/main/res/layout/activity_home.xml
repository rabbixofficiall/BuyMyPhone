<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0B0F14"
    android:padding="20dp">

    <!-- App Title -->
    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BuyMyPhone"
        android:textColor="#FFFFFF"
        android:textSize="30sp"
        android:textStyle="bold" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/txtSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Smart device analyzer"
        android:textColor="#94A3B8"
        android:textSize="14sp"
        android:layout_marginTop="6dp" />

    <!-- Spacer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="30dp" />

    <!-- Start Button -->
    <Button
        android:id="@+id/btnStartAnalysis"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Start Analysis"
        android:textAllCaps="false"
        android:background="@drawable/button_neon"
        android:textColor="#000000" />

    <!-- About Button -->
    <Button
        android:id="@+id/btnAboutApp"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="12dp"
        android:text="About This App"
        android:textAllCaps="false"
        android:backgroundTint="#1E2630"
        android:textColor="#FFFFFF" />

    <!-- Premium Button -->
    <Button
        android:id="@+id/btnGoPremium"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="12dp"
        android:text="Go Premium"
        android:textAllCaps="false"
        android:backgroundTint="#1E2630"
        android:textColor="#FFFFFF" />

    <!-- Ad Container -->
    <FrameLayout
        android:id="@+id/adContainerHome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp" />

</LinearLayout>
