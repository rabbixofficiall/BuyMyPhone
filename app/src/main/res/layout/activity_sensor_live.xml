<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/txtSensorLiveTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sensor Live Test"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtSensorLiveSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Live values from major sensors."
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/glass_bg"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/txtAccelerometer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Accelerometer: Waiting..."
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/txtGyroscope"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Gyroscope: Waiting..."
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/txtCompass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Compass / Magnetic Field: Waiting..."
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/txtLightSensor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Light Sensor: Waiting..."
                android:textColor="@color/text_primary"
                android:textSize="15sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnBackSensorLive"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/button_secondary"
            android:text="Back"
            android:textAllCaps="false"
            android:textColor="@color/button_secondary_text" />

    </LinearLayout>
</ScrollView>
