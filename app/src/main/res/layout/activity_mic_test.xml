<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_bg"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/txtMicStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap Start to record for 3 seconds."
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnStartMicTest"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/button_secondary"
        android:text="Start Mic Test"
        android:textAllCaps="false"
        android:textColor="@color/button_secondary_text" />

    <Button
        android:id="@+id/btnBackMicTest"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/button_secondary"
        android:text="Back"
        android:textAllCaps="false"
        android:textColor="@color/button_secondary_text" />

</LinearLayout>
