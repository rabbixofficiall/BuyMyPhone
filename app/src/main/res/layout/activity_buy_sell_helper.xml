<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_bg">

    <LinearLayout
        android:id="@+id/rootBuySellHelper"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/txtBuySellTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Buy / Sell Helper"
            android:textColor="@color/text_primary"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtBuySellSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Automatic deep analysis result"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/glass_bg"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/txtFinalVerdictTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Final Verdict"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtFinalVerdict"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/text_primary"
                android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/glass_bg"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/txtBuyReasonsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Why You May Buy"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtBuyReasons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/glass_bg"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/txtAvoidReasonsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Why You May Avoid"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtAvoidReasons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnSaveSoftwarePdf"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/button_secondary"
            android:text="Save Software PDF"
            android:textAllCaps="false"
            android:textColor="@color/button_secondary_text"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnSaveHardwarePdf"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/button_secondary"
            android:text="Save Hardware PDF"
            android:textAllCaps="false"
            android:textColor="@color/button_secondary_text"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnBackBuySellHelper"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/button_secondary"
            android:text="Back"
            android:textAllCaps="false"
            android:textColor="@color/button_secondary_text" />

    </LinearLayout>
</ScrollView>
