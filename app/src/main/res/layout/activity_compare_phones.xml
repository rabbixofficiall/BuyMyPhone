<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/txtCompareTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Compare Two Phones"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtCompareSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Select two saved reports to compare old vs new phone."
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <Spinner
            android:id="@+id/spinnerFirstPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/button_secondary" />

        <Spinner
            android:id="@+id/spinnerSecondPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/button_secondary" />

        <Button
            android:id="@+id/btnRunCompare"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/button_secondary"
            android:text="Compare"
            android:textAllCaps="false"
            android:textColor="@color/button_secondary_text"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/glass_bg"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/txtCompareResultTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Comparison Result"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtCompareResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Select two reports and tap Compare."
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnBackCompare"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/button_secondary"
            android:text="Back"
            android:textAllCaps="false"
            android:textColor="@color/button_secondary_text" />

    </LinearLayout>
</ScrollView>
