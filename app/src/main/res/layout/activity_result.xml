package com.buymyphone.app.ui.result

import android.os.Build
import android.os.Bundle
import androidx.appcompat.app.AppCompatActivity
import com.buymyphone.app.databinding.ActivityResultBinding

class ResultActivity : AppCompatActivity() {

    private lateinit var binding: ActivityResultBinding

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        binding = ActivityResultBinding.inflate(layoutInflater)
        setContentView(binding.root)

        loadFakeAnalysis() // demo data (stable, no crash)
    }

    private fun loadFakeAnalysis() {

        // 🔥 REAL DEVICE NAME (no demo device issue)
        val deviceName = "${Build.MANUFACTURER} ${Build.MODEL}"

        // 🔥 smart calculated score (simple but realistic)
        val overallScore = calculateScore()

        // 🔵 Circular animation
        binding.circularScore.setScoreAnimated(overallScore)

        // 🧠 Verdict
        val verdict = getVerdict(overallScore)

        // 🧊 Show summary
        binding.txtVerdict.text = """
Device: $deviceName

Score: $overallScore / 100

$verdict
        """.trimIndent()
    }

    private fun calculateScore(): Int {
        val sdkScore = when {
            Build.VERSION.SDK_INT >= 33 -> 90
            Build.VERSION.SDK_INT >= 30 -> 80
            Build.VERSION.SDK_INT >= 28 -> 70
            else -> 60
        }

        val brandBoost = when {
            Build.BRAND.contains("samsung", true) -> 5
            Build.BRAND.contains("xiaomi", true) -> 4
            Build.BRAND.contains("realme", true) -> 4
            else -> 2
        }

        val modelLengthFactor = Build.MODEL.length % 5

        return (sdkScore + brandBoost + modelLengthFactor).coerceAtMost(100)
    }

    private fun getVerdict(score: Int): String {
        return when {
            score >= 90 -> "🔥 Flagship performance. Excellent for gaming & heavy use."
            score >= 75 -> "⚡ Very good device. Smooth daily usage and multitasking."
            score >= 60 -> "👍 Decent performance. Good for normal tasks."
            else -> "⚠️ Basic device. Suitable for light usage only."
        }
    }
}
