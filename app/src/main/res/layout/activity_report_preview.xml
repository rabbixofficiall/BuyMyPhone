<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/analysis_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/txtPreviewTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="REPORT PREVIEW"
            android:textColor="@color/analysis_primary"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtPreviewSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="monospace"
            android:text="Full device information"
            android:textColor="@color/analysis_secondary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txtReportContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:fontFamily="monospace"
            android:lineSpacingExtra="5dp"
            android:textColor="@color/analysis_primary"
            android:textIsSelectable="true"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnClosePreview"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/button_secondary"
            android:text="Back"
            android:textAllCaps="false"
            android:textColor="@color/button_secondary_text" />

    </LinearLayout>
</ScrollView>
