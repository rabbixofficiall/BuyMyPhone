<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:name=".BuyMyPhoneApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="BuyMyPhone"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.BuyMyPhone">

        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="@string/admob_app_id" />

        <activity
            android:name=".ui.heavyapps.HeavyAppsDetectorActivity"
            android:exported="false" />

        <activity
            android:name=".ui.compare.ComparePhonesActivity"
            android:exported="false" />

        <activity
            android:name=".ui.battery.BatteryDeepAnalysisActivity"
            android:exported="false" />

        <activity
            android:name=".ui.sensor.SensorLiveActivity"
            android:exported="false" />

        <activity
            android:name=".ui.hardware.FingerprintCheckActivity"
            android:exported="false" />

        <activity
            android:name=".ui.hardware.FlashlightTestActivity"
            android:exported="false" />

        <activity
            android:name=".ui.hardware.ProximityTestActivity"
            android:exported="false" />

        <activity
            android:name=".ui.hardware.VibrationTestActivity"
            android:exported="false" />

        <activity
            android:name=".ui.hardware.MicTestActivity"
            android:exported="false" />

        <activity
            android:name=".ui.hardware.SpeakerTestActivity"
            android:exported="false" />

        <activity
            android:name=".ui.hardware.DeadPixelTestActivity"
            android:exported="false" />

        <activity
            android:name=".ui.hardware.TouchscreenTestActivity"
            android:exported="false" />

        <activity
            android:name=".ui.hardware.HardwareTestHubActivity"
            android:exported="false" />

        <activity
            android:name=".ui.deepanalysis.DeepAnalysisActivity"
            android:exported="false" />

        <activity
            android:name=".ui.reports.ReportsActivity"
            android:exported="false" />

        <activity
            android:name=".ui.settings.SettingsActivity"
            android:exported="false" />

        <activity
            android:name=".ui.premium.PremiumActivity"
            android:exported="false" />

        <activity
            android:name=".ui.report.ReportPreviewActivity"
            android:exported="false" />

        <activity
            android:name=".ui.result.ResultActivity"
            android:exported="false" />

        <activity
            android:name=".ui.analysis.AnalysisActivity"
            android:exported="false" />

        <activity
            android:name=".ui.about.AboutActivity"
            android:exported="false" />

        <activity
            android:name=".ui.home.HomeActivity"
            android:exported="false" />

        <activity
            android:name=".ui.splash.SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>
